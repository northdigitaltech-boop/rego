# Copy this file to ".env.local" and fill in the two values
# from your Supabase project: Dashboard → Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# NOTE: Only the URL and the "anon public" key go here.
# NEVER put the "service_role" secret key in this file.

# Cloudinary (image uploads) — from cloudinary.com
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=your-unsigned-preset

# Resend (email confirmations) — from resend.com  (SERVER secret, no NEXT_PUBLIC)
RESEND_API_KEY=re_your_api_key
# EMAIL_FROM=SAFARIGB <onboarding@resend.dev>   # change after you verify a domain

# Google Maps (destination autocomplete) — from console.cloud.google.com
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-key

# ---- SEO ----
# Canonical public origin. MUST be the production domain in production.
# Leave unset locally; preview/staging should set their own (non-rego.services) host.
NEXT_PUBLIC_SITE_URL=https://rego.services
# Search Console / Webmaster verification tokens (optional; added to <head> when present).
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_BING_SITE_VERIFICATION=
NEXT_PUBLIC_YANDEX_VERIFICATION=
# Indexing overrides (normally NOT needed — indexing is automatic on the prod domain):
#   NEXT_PUBLIC_SEO_NOINDEX=true      # force noindex everywhere (e.g. a locked-down launch)
#   NEXT_PUBLIC_SEO_FORCE_INDEX=true  # force indexing on a non-standard host (use with care)

# Rego Map — premium base tiles (optional). Public keys (safe in browser; restrict by URL).
# Preferred: MapTiler — FREE, NO credit card needed. https://cloud.maptiler.com/account/keys/
NEXT_PUBLIC_MAPTILER_KEY=your-maptiler-key
# Alternative: Mapbox (needs a card on file). Used only if MapTiler key is empty.
# NEXT_PUBLIC_MAPBOX_TOKEN=pk.your-mapbox-public-token
# Without either, the map uses free OpenTopoMap / Esri / CARTO tiles.

# Rego AI (optional) — natural, LLM-grounded answers. SERVER secrets, no NEXT_PUBLIC.
# Leave blank to use the built-in rule-based assistant (free, always works).
# Pick ONE provider and set REGO_AI_PROVIDER to match, then add its key.
#
# FREE to start (no credit card):
# REGO_AI_PROVIDER=groq             # get a free key at https://console.groq.com/keys
# GROQ_API_KEY=gsk_...              # model default: llama-3.3-70b-versatile
#
# REGO_AI_PROVIDER=openrouter       # free models, https://openrouter.ai/keys
# OPENROUTER_API_KEY=sk-or-...      # model default: meta-llama/llama-3.1-8b-instruct:free
#
# REGO_AI_PROVIDER=gemini           # https://aistudio.google.com/apikey (region-limited)
# GEMINI_API_KEY=...                # model default: gemini-2.0-flash
#
# Paid:
# REGO_AI_PROVIDER=openai           # OPENAI_API_KEY=sk-...    (default gpt-4o-mini)
# REGO_AI_PROVIDER=anthropic        # ANTHROPIC_API_KEY=sk-ant-... (default claude-3-5-haiku-latest)
#
# REGO_AI_MODEL=                    # optional model override for any provider
